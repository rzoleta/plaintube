# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth credentials (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: YouTube Data API key (API calls use OAuth token; key reserved for future use)
YOUTUBE_API_KEY=

# Set to your production URL for Auth.js redirect URIs
# AUTH_URL=https://plaintube.tv
